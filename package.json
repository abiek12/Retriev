{
  "name": "with-vite-react",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.10.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.9"
    }
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@hono/zod-validator": "^0.9.0",
    "zod": "^4.4.3"
  }
}
